{
  "name": "video-editor-ai-agent",
  "version": "0.3.0",
  "description": "AI Video Editor Agent — Arabic lecturer Reels pipeline (Remotion + faster-whisper + MediaPipe + librosa)",
  "type": "module",
  "private": true,
  "bin": {
    "rs-reels": "./rs-reels.mjs"
  },
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render",
    "make": "node rs-reels.mjs",
    "dashboard:api": "node dashboard-api/server.mjs",
    "dashboard:ui": "cd dashboard-ui && npm run dev",
    "dashboard": "concurrently --names api,ui --prefix-colors yellow,cyan \"npm run dashboard:api\" \"npm run dashboard:ui\"",
    "typecheck": "tsc --noEmit",
    "typecheck:dashboard": "cd dashboard-ui && tsc --noEmit",
    "typecheck:editor": "cd subtitle-editor && tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:dashboard && npm run typecheck:editor",
    "test": "node --test \"dashboard-api/lib/__tests__/**/*.test.mjs\""
  },
  "dependencies": {
    "@remotion/cli": "^4.0.448",
    "@remotion/google-fonts": "^4.0.448",
    "@remotion/layout-utils": "^4.0.448",
    "@remotion/media-utils": "^4.0.448",
    "@remotion/motion-blur": "^4.0.448",
    "@remotion/paths": "^4.0.448",
    "@remotion/shapes": "^4.0.448",
    "@remotion/transitions": "^4.0.448",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.448"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  }
}
