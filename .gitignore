# ─── Dependencies ───
node_modules/
.pnp/
.pnp.js

# ─── Build outputs ───
dist/
build/
out/
.cache/

# ─── Auto-generated render props (rewritten on every render) ───
.props/

# ─── TypeScript incremental build cache ───
tsconfig.tsbuildinfo

# ─── Per-video files anywhere (always too large or ephemeral) ───
# These live next to the source video on the user's drive, never in the repo.
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.wav
*.mp3
*.flac
*.aac
*.m4a

# Large image source files
*.psd

# Per-video pipeline outputs (face_map, energy, captions, zoom plans, metadata)
# These are derived from the source video and live next to it.
*.face_map.json
*.energy.json
*.zoom_plan.json
*.metadata.json
*.captions.json
*.captions.srt
# Raw Whisper output (snapshot before user review) — per-video, not committed
*.captions.raw.json
# But keep tiny test fixtures in samples/
!samples/**
# Keep SFX library (synthesized short clips committed to the repo so
# Remotion's staticFile() can reference them at render time).
!public/sfx/**

# ─── Per-project working dirs (populated at runtime, never committed) ───
/data/
/input/
/output/

# Note: src/data/ is the AI agent learning loop store — IS committed.
# Keep `data/` rules anchored to root (with leading /) so they don't catch src/data/.

# ─── Dashboard state files — per-installation, not committed ───
dashboard-api/state/videos.json
dashboard-api/node_modules/

# ─── OS files ───
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
